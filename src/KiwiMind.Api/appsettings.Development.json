{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=kiwimind;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Secret": "dev-only-local-signing-key-not-for-production-use-1234567890",
